# Prisma / PostgreSQL
#
# Локально / на своём VPS (Docker): см. docker-compose.yml
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/client_say?schema=public"
#
# Vercel / Netlify / любой serverless: только облачный Postgres (Neon, Supabase, Railway…).
# НЕ используйте 127.0.0.1 или localhost — это «ваш компьютер», а не сервер в облаке.
# Пример Neon: postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Required in production for JWT signing (minimum 32 characters)
AUTH_SECRET="replace-with-long-random-secret-at-least-32-chars"

# Prisma / PostgreSQL (на VPS: 127.0.0.1 после `docker compose up -d db` в каталоге приложения)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/client_say?schema=public"

# Required in production for JWT signing (minimum 32 characters)
AUTH_SECRET="replace-with-long-random-secret-at-least-32-chars"

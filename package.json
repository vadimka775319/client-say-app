{
  "name": "client-say-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "env:init": "node scripts/env-init.cjs",
    "dev": "next dev",
    "build": "node scripts/write-deploy-meta.cjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:release": "npm run lint && npm run typecheck && node scripts/verify-release.cjs",
    "db:generate": "prisma generate",
    "db:docker": "docker compose up -d",
    "db:docker:down": "docker compose down",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:sync": "prisma db push && prisma db seed",
    "prod:health": "node scripts/run-ps1.cjs prod-health-check.ps1",
    "vps:db": "node scripts/run-ps1.cjs vps-fix-db-stack.ps1",
    "vps:diag": "node scripts/run-ps1.cjs vps-diagnose.ps1",
    "git:save": "node scripts/run-ps1.cjs sync-github.ps1",
    "git:push": "node scripts/run-ps1.cjs sync-github.ps1 -Push"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/onest": "^5.2.11",
    "@prisma/client": "5.22.0",
    "@tailwindcss/postcss": "^4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "jose": "^6.2.2",
    "next": "16.2.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
